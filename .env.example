# --- 네이버 지도 (브라우저 Dynamic Map) ---
# 웹 지도는 Client ID만 스크립트 URL에 사용합니다. Client Secret은 지도 표시에 필요 없습니다.
# Secret은 역지오코딩 등 "REST API를 서버에서 호출"할 때만 사용하세요. (NEXT_PUBLIC 붙이면 안 됨)
#
# 아래 둘 중 하나만 넣어도 됩니다 (둘 다 있으면 NEXT_PUBLIC_ 값이 우선).
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=m7zqql57ak
NAVER_MAP_CLIENT_ID=m7zqql57ak

# 서버 전용 (선택). 절대 NEXT_PUBLIC_ 로 노출하지 마세요.
NAVER_MAP_CLIENT_SECRET=

# 네이버 클라우드 콘솔 > Application > Web 서비스 URL에 반드시 등록:
#   http://localhost:3000
#   실제 배포 도메인 (https://...)

# --- 카카오 ---
NEXT_PUBLIC_KAKAO_JS_KEY=

# --- Supabase (RSVP Server Action — 서버에서만 사용) ---
# 프로젝트 URL: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
# Service Role Key: Dashboard > API > service_role (절대 클라이언트/깃에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=
